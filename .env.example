S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

FCM_SERVER_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=5

ADMIN_PANEL_ORIGIN=http://localhost:3001
VENDOR_PANEL_ORIGIN=http://localhost:3002
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

SUPER_ADMIN_EMAIL=superadmin@pawdigi.local
