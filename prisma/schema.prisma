generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  GUARDIAN
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum GuardianPermission {
  VIEW_ONLY
  MANAGE_HEALTH_RECORDS
  MANAGE_REMINDERS
  FULL_ACCESS
}

enum PetSpecies {
  DOG
  CAT
  BIRD
  RABBIT
  OTHER
}

enum PetGender {
  MALE
  FEMALE
  UNKNOWN
}

enum ReminderType {
  VACCINATION
  DEWORMING
  VET_VISIT
  MEDICINE
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SENT
  COMPLETED
  OVERDUE
  CANCELLED
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum MedicalRecordType {
  PRESCRIPTION
  LAB_REPORT
  SURGERY
  ALLERGY
  GENERAL_CHECKUP
  CERTIFICATE
  OTHER
}

enum DocumentType {
  MEDICAL_REPORT
  VACCINATION_CERTIFICATE
  PASSPORT_PDF
  VENDOR_KYC
  PRODUCT_IMAGE
  OTHER
}

enum DocumentVisibility {
  PRIVATE
  PET_OWNER_ONLY
  GUARDIAN_ALLOWED
  PUBLIC_SHARE
  ADMIN_ONLY
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  REJECTED
  OUT_OF_STOCK
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ShipmentStatus {
  PENDING
  READY_TO_SHIP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum SchedulerRunStatus {
  STARTED
  SUCCESS
  FAILED
  SKIPPED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
  MERGED
  EXPIRED
  CLEARED
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

model User {
  id               String            @id @default(uuid())
  email            String?           @unique
  phoneNumber      String?           @unique
  passwordHash     String?
  role             Role
  status           UserStatus        @default(ACTIVE)
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  customerProfile  CustomerProfile?
  adminProfile     AdminProfile?
  vendorProfile    VendorProfile?
  ownedPets        Pet[]             @relation("PetOwner")
  guardianPets     PetGuardian[]     @relation("GuardianUser")
  reminders        Reminder[]
  notifications    Notification[]
  deviceTokens     DeviceToken[]
  documents        Document[]        @relation("DocumentOwner")
  cart             Cart?
  orders           Order[]           @relation("CustomerOrders")
  reviews          Review[]
  refreshTokens    RefreshToken[]
  otpVerifications OtpVerification[]
  auditLogs        AuditLog[]        @relation("ActorAuditLogs")
  apiRequestLogs   ApiRequestLog[]

  @@index([email])
  @@index([phoneNumber])
  @@map("users")
}

model OtpVerification {
  id                String    @id @default(uuid())
  phoneNumber       String
  otpCode           String
  otpHash           String
  purpose           String    @default("LOGIN")
  deliveryChannel   String    @default("SMS")
  deliveryProvider  String?
  deliveryStatus    String    @default("PENDING")
  deliveryMessage   String?
  deviceId          String?
  platform          String?
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5)
  lastAttemptAt     DateTime?
  expiresAt         DateTime
  deliveredAt       DateTime?
  verifiedAt        DateTime?
  failedAt          DateTime?
  failureReason     String?
  requestIpAddress  String?
  verifiedIpAddress String?
  userAgent         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])

  @@index([phoneNumber])
  @@index([expiresAt])
  @@index([deliveryStatus])
  @@index([verifiedAt])
  @@map("otp_challenges")
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("customer_profiles")
}

model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("admin_profiles")
}

model VendorProfile {
  id              String       @id @default(uuid())
  userId          String       @unique
  businessName    String
  contactPerson   String?
  email           String
  phoneNumber     String?
  gstNumber       String?
  panNumber       String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  status          VendorStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  user            User         @relation(fields: [userId], references: [id])
  products        Product[]
  orders          Order[]      @relation("VendorOrders")
  documents       Document[]

  @@index([status])
  @@map("vendor_profiles")
}

model Pet {
  id              String              @id @default(uuid())
  ownerId         String
  name            String
  species         PetSpecies
  breed           String?
  gender          PetGender?
  dateOfBirth     DateTime?
  weight          Decimal?            @db.Decimal(8, 2)
  color           String?
  microchipNumber String?
  profileImageUrl String?
  passportNumber  String?             @unique
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  owner           User                @relation("PetOwner", fields: [ownerId], references: [id])
  guardians       PetGuardian[]
  passport        PetPassport?
  vaccinations    VaccinationRecord[]
  deworming       DewormingRecord[]
  medicalRecords  MedicalRecord[]
  documents       Document[]
  reminders       Reminder[]

  @@index([ownerId])
  @@map("pets")
}

model PetGuardian {
  id             String             @id @default(uuid())
  petId          String
  guardianUserId String?
  inviteEmail    String?
  invitePhone    String?
  inviteToken    String             @unique
  permission     GuardianPermission
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  pet            Pet                @relation(fields: [petId], references: [id])
  guardianUser   User?              @relation("GuardianUser", fields: [guardianUserId], references: [id])

  @@index([petId])
  @@index([guardianUserId])
  @@map("pet_guardians")
}

model PetPassport {
  id                 String    @id @default(uuid())
  petId              String    @unique
  passportNo         String    @unique
  status             String    @default("ACTIVE")
  issuedAt           DateTime  @default(now())
  issuedBy           String?
  expiresAt          DateTime?
  version            Int       @default(1)
  qrCodeUrl          String?
  publicProfileUrl   String?
  shareToken         String?   @unique
  shareExpires       DateTime?
  shareRevoked       Boolean   @default(false)
  shareRevokedAt     DateTime?
  shareRevokedReason String?
  lastSharedAt       DateTime?
  viewCount          Int       @default(0)
  lastViewedAt       DateTime?
  pdfDocumentId      String?
  pdfGeneratedAt     DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  pet                Pet       @relation(fields: [petId], references: [id])

  @@index([passportNo])
  @@index([status])
  @@index([shareExpires])
  @@map("pet_passports")
}

model VaccinationRecord {
  id              String    @id @default(uuid())
  petId           String
  vaccineName     String
  vaccinationDate DateTime
  nextDueDate     DateTime?
  vetName         String?
  clinicName      String?
  batchNumber     String?
  notes           String?
  documentId      String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  pet             Pet       @relation(fields: [petId], references: [id])
  document        Document? @relation(fields: [documentId], references: [id])

  @@index([petId])
  @@map("vaccination_records")
}

model DewormingRecord {
  id           String    @id @default(uuid())
  petId        String
  medicineName String
  givenDate    DateTime
  nextDueDate  DateTime?
  dosage       String?
  vetName      String?
  notes        String?
  documentId   String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  pet          Pet       @relation(fields: [petId], references: [id])
  document     Document? @relation(fields: [documentId], references: [id])

  @@index([petId])
  @@map("deworming_records")
}

model MedicalRecord {
  id          String            @id @default(uuid())
  petId       String
  recordType  MedicalRecordType
  title       String
  description String?
  recordDate  DateTime
  vetName     String?
  clinicName  String?
  documentId  String?
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  pet         Pet               @relation(fields: [petId], references: [id])
  document    Document?         @relation(fields: [documentId], references: [id])

  @@index([petId])
  @@map("medical_records")
}

model Reminder {
  id          String         @id @default(uuid())
  petId       String
  userId      String
  type        ReminderType
  title       String
  description String?
  dueDate     DateTime
  repeatType  RepeatType     @default(NONE)
  status      ReminderStatus @default(PENDING)
  lastSentAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  pet         Pet            @relation(fields: [petId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  @@index([dueDate])
  @@index([status])
  @@map("reminders")
}

model Notification {
  id                String             @id @default(uuid())
  userId            String
  title             String
  body              String
  data              Json?
  type              String?
  channel           String             @default("PUSH")
  status            NotificationStatus @default(QUEUED)
  priority          String             @default("NORMAL")
  provider          String?
  providerMessageId String?
  failureReason     String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model DeviceToken {
  id               String    @id @default(uuid())
  userId           String
  deviceId         String
  fcmToken         String
  platform         String
  appVersion       String?
  osVersion        String?
  deviceModel      String?
  locale           String?
  timezone         String?
  ipAddress        String?
  userAgent        String?
  isActive         Boolean   @default(true)
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  revocationReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([platform])
  @@index([isActive])
  @@index([lastSeenAt])
  @@map("device_tokens")
}

model Document {
  id             String              @id @default(uuid())
  ownerId        String
  petId          String?
  vendorId       String?
  type           DocumentType
  fileName       String
  mimeType       String
  size           Int
  storageKey     String              @unique
  storageUrl     String?
  visibility     DocumentVisibility  @default(PRIVATE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  owner          User                @relation("DocumentOwner", fields: [ownerId], references: [id])
  pet            Pet?                @relation(fields: [petId], references: [id])
  vendor         VendorProfile?      @relation(fields: [vendorId], references: [id])
  vaccinations   VaccinationRecord[]
  deworming      DewormingRecord[]
  medicalRecords MedicalRecord[]

  @@map("documents")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  parentId  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@map("categories")
}

model Product {
  id            String         @id @default(uuid())
  vendorId      String
  categoryId    String
  name          String
  sku           String         @unique
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  discountPrice Decimal?       @db.Decimal(12, 2)
  petType       PetSpecies?
  status        ProductStatus  @default(DRAFT)
  isFeatured    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  vendor        VendorProfile  @relation(fields: [vendorId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  inventory     Inventory?
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]

  @@index([vendorId])
  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id         String    @id @default(uuid())
  productId  String
  url        String
  storageKey String?
  altText    String?
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  checksum   String?
  sortOrder  Int       @default(0)
  isPrimary  Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  product    Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([isPrimary])
  @@index([isActive])
  @@map("product_images")
}

model Inventory {
  id              String    @id @default(uuid())
  productId       String    @unique
  stock           Int       @default(0)
  reserved        Int       @default(0)
  available       Int       @default(0)
  lowStockAlert   Int       @default(5)
  reorderPoint    Int?
  reorderQuantity Int?
  warehouseCode   String?
  binLocation     String?
  batchNumber     String?
  expiresAt       DateTime?
  lastRestockedAt DateTime?
  lastSoldAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  product         Product   @relation(fields: [productId], references: [id])

  @@index([stock])
  @@index([available])
  @@index([warehouseCode])
  @@map("inventories")
}

model Cart {
  id             String     @id @default(uuid())
  customerId     String     @unique
  status         CartStatus @default(ACTIVE)
  currency       String     @default("INR")
  subtotalAmount Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal    @default(0) @db.Decimal(12, 2)
  shippingAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal    @default(0) @db.Decimal(12, 2)
  itemCount      Int        @default(0)
  couponCode     String?
  source         String?
  deviceId       String?
  ipAddress      String?
  userAgent      String?
  checkedOutAt   DateTime?
  abandonedAt    DateTime?
  expiresAt      DateTime?
  lastActivityAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  customer       User       @relation(fields: [customerId], references: [id])
  items          CartItem[]

  @@index([customerId])
  @@index([status])
  @@index([lastActivityAt])
  @@map("carts")
}

model CartItem {
  id              String    @id @default(uuid())
  cartId          String
  productId       String
  quantity        Int
  unitPrice       Decimal?  @db.Decimal(12, 2)
  mrp             Decimal?  @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal       Decimal   @default(0) @db.Decimal(12, 2)
  productName     String?
  productSku      String?
  vendorId        String?
  metadata        Json?
  addedAt         DateTime  @default(now())
  savedForLaterAt DateTime?
  removedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cart            Cart      @relation(fields: [cartId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@index([vendorId])
  @@map("cart_items")
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String?
  customerId         String
  vendorId           String
  status             OrderStatus   @default(PLACED)
  currency           String        @default("INR")
  subtotalAmount     Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @db.Decimal(12, 2)
  shippingAmount     Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2)
  itemCount          Int           @default(0)
  couponCode         String?
  address            Json
  billingAddress     Json?
  notes              String?
  cancellationReason String?
  placedAt           DateTime      @default(now())
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  deliveredAt        DateTime?
  source             String?
  deviceId           String?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  customer           User          @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor             VendorProfile @relation("VendorOrders", fields: [vendorId], references: [id])
  items              OrderItem[]
  payment            Payment?
  shipment           Shipment?

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([orderNumber])
  @@index([placedAt])
  @@map("orders")
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String
  vendorId          String?
  productName       String?
  productSku        String?
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  mrp               Decimal? @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal         Decimal  @default(0) @db.Decimal(12, 2)
  fulfillmentStatus String   @default("PENDING")
  returnStatus      String?
  refundStatus      String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id])
  product           Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([vendorId])
  @@map("order_items")
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  provider          String
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(12, 2)
  capturedAmount    Decimal       @default(0) @db.Decimal(12, 2)
  refundedAmount    Decimal       @default(0) @db.Decimal(12, 2)
  currency          String        @default("INR")
  paymentMethod     String?
  paymentInstrument String?
  payerEmail        String?
  payerPhone        String?
  failureCode       String?
  failureReason     String?
  refundProviderId  String?
  refundStatus      String?
  refundReason      String?
  authorizedAt      DateTime?
  capturedAt        DateTime?
  failedAt          DateTime?
  refundedAt        DateTime?
  webhookEventId    String?       @unique
  lastWebhookEvent  String?
  rawPayload        Json?
  rawWebhookPayload Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerOrderId])
  @@index([providerPaymentId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Shipment {
  id                  String         @id @default(uuid())
  orderId             String         @unique
  status              ShipmentStatus @default(PENDING)
  carrier             String?
  carrierService      String?
  trackingNumber      String?
  trackingUrl         String?
  awbNumber           String?
  labelUrl            String?
  pickupAddress       Json?
  deliveryAddress     Json?
  packageWeightGrams  Int?
  packageLengthCm     Decimal?       @db.Decimal(8, 2)
  packageWidthCm      Decimal?       @db.Decimal(8, 2)
  packageHeightCm     Decimal?       @db.Decimal(8, 2)
  shippingCost        Decimal?       @db.Decimal(12, 2)
  estimatedDeliveryAt DateTime?
  pickupScheduledAt   DateTime?
  pickedUpAt          DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  rawPayload          Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  order               Order          @relation(fields: [orderId], references: [id])

  @@index([status])
  @@index([carrier])
  @@index([trackingNumber])
  @@map("shipments")
}

model Review {
  id                 String       @id @default(uuid())
  productId          String
  customerId         String
  orderId            String?
  rating             Int
  title              String?
  comment            String?
  status             ReviewStatus @default(PENDING)
  isVerifiedPurchase Boolean      @default(false)
  helpfulCount       Int          @default(0)
  reportCount        Int          @default(0)
  rejectionReason    String?
  moderatedBy        String?
  moderatedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?
  product            Product      @relation(fields: [productId], references: [id])
  customer           User         @relation(fields: [customerId], references: [id])

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorRole   Role?
  action      String
  entityType  String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id])

  @@map("audit_event_logs")
}

model ApiRequestLog {
  id             String   @id @default(uuid())
  requestId      String?
  userId         String?
  userRole       Role?
  method         String
  path           String
  route          String?
  query          Json?
  body           Json?
  params         Json?
  statusCode     Int?
  status         String
  errorName      String?
  errorMessage   String?
  durationMs     Int
  ipAddress      String?
  userAgent      String?
  referer        String?
  contentLength  Int?
  responseLength Int?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([method])
  @@index([path])
  @@index([status])
  @@index([statusCode])
  @@index([createdAt])
  @@map("api_request_logs")
}

model SchedulerRunLog {
  id             String             @id @default(uuid())
  schedulerName  String
  queueName      String?
  jobName        String?
  bullJobId      String?
  repeatJobKey   String?
  status         SchedulerRunStatus @default(STARTED)
  triggerType    String?
  attempt        Int?
  maxAttempts    Int?
  input          Json?
  output         Json?
  itemsProcessed Int?
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  errorName      String?
  errorMessage   String?
  errorStack     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([schedulerName])
  @@index([queueName])
  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
  @@index([bullJobId])
  @@map("scheduler_execution_logs")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String
  sessionLabel      String?
  deviceId          String?
  platform          String?
  ipAddress         String?
  userAgent         String?
  expiresAt         DateTime
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  revocationReason  String?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token_sessions")
}
